---
import { getImage, Image } from "astro:assets";
import DatasetBadge from "@/assets/dataset-on-hf-lg.svg";
import DatasetBadgeDark from "@/assets/dataset-on-hf-lg-dark.svg";
import demoVideo from "@/assets/demo.mp4";
import posterImage from "@/assets/poster.jpg";
import type { Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;

const videoAlt = "ub-MOJI hero video";
const optimizedPoster = await getImage({ src: posterImage });
---

<section
  class="flex min-h-svh w-full flex-col justify-start gap-6 bg-background px-4 pb-6 pt-8 sm:justify-center sm:gap-12 sm:pt-6"
  data-testid="hero"
>
  <div class="mx-auto w-full max-w-5xl">
    <div class="relative grid place-items-center">
      <div class="relative w-full overflow-hidden rounded-[2rem] border border-border/60 bg-black/30 shadow-[0_24px_80px_rgba(0,0,0,0.25)] aspect-[9/16] max-h-[56svh] min-h-[16rem] sm:aspect-[16/9] sm:max-h-[52svh]">
        <div class="absolute inset-0">
          <video
            class="h-full w-full object-cover motion-reduce:hidden"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            poster={optimizedPoster.src}
            aria-label={videoAlt}
            data-testid="hero-video"
          >
            <source src={demoVideo} type="video/mp4" />
            <Image class="h-full w-full object-cover" src={posterImage} alt={videoAlt} priority />
          </video>
          <Image
            class="hidden h-full w-full object-cover motion-reduce:block"
            src={posterImage}
            alt={videoAlt}
            priority
          />
          <div
            class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/55"
            aria-hidden="true"
          ></div>
        </div>

        <div class="relative z-10 flex h-full items-center justify-center px-6 py-6">
          <span
            class="text-balance text-center text-[clamp(2rem,7vw,4.5rem)] font-semibold tracking-[0.08em] text-white drop-shadow-[0_8px_28px_rgba(0,0,0,0.45)]"
            data-testid="hero-overlay"
          >
            ub-MOJI
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto w-full max-w-5xl px-4" data-testid="dataset-overview">
    <div class="max-w-3xl">
      <h1 class="text-balance text-lg font-semibold tracking-[0.02em] text-foreground sm:text-2xl md:text-3xl">
        {t(locale, "datasetTitle")}
      </h1>
      <p class="mt-3 text-balance text-sm leading-relaxed text-muted-foreground sm:mt-4 sm:text-base">
        {t(locale, "datasetBody")}
      </p>
      <div class="mt-4 flex flex-wrap items-center gap-4 sm:mt-6">
        <a
          class="group inline-flex items-center p-1 transition-transform duration-300 hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-ring/30"
          href="https://huggingface.co/datasets/kanglabs/ub-MOJI"
          aria-label={t(locale, "datasetCtaAlt")}
        >
          <DatasetBadge
            class="h-10 w-auto drop-shadow-[0_8px_24px_rgba(0,0,0,0.12)] sm:h-12 dark:hidden"
            aria-hidden="true"
          />
          <DatasetBadgeDark
            class="hidden h-10 w-auto drop-shadow-[0_8px_24px_rgba(0,0,0,0.35)] sm:h-12 dark:block"
            aria-hidden="true"
          />
        </a>
      </div>
    </div>
  </div>
</section>
