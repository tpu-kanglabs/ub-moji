---
import { defaultLocale, isLocale, t } from "@/lib/i18n";

const { lang } = Astro.props;
const locale = isLocale(lang) ? lang : defaultLocale;
const logoSrc = `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}favicon.svg`;
---

<footer data-testid="site-footer" class="border-t border-border/60 bg-muted/40">
  <div class="mx-auto flex w-full max-w-5xl items-center justify-between gap-4 px-4 py-6 text-sm">
    <div class="flex items-center gap-3">
      <img
        data-testid="site-footer-logo"
        src={logoSrc}
        alt={t(locale, "footerLogoAlt")}
        class="size-9 object-contain"
      />
      <div class="flex flex-col gap-0.5">
        <span class="font-medium">{t(locale, "siteName")}</span>
        <span class="text-xs text-muted-foreground">
          © 映像情報処理研究室 / AI Vision Lab.
        </span>
      </div>
    </div>
    <nav class="flex items-center gap-4 text-muted-foreground">
      <a
        href="https://www.kanglabs.net/"
        target="_blank"
        rel="noopener noreferrer"
        class="transition hover:text-foreground"
      >{t(locale, "footerLabWebsite")}</a>
      <a
        href="https://github.com/tpu-kanglabs/"
        target="_blank"
        rel="noopener noreferrer"
        class="transition hover:text-foreground"
      >{t(locale, "footerGitHub")}</a>
      <a
        href="https://huggingface.co/kanglabs"
        target="_blank"
        rel="noopener noreferrer"
        class="transition hover:text-foreground"
      >{t(locale, "footerHuggingFace")}</a>
    </nav>
  </div>
</footer>
