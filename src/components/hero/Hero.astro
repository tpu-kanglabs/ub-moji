---
import demoVideo from "@/assets/demo.mp4";
import posterImage from "@/assets/poster.jpg";

const videoAlt = "ub-MOJI hero video";
---

<section class="w-full bg-background pb-10 pt-6" data-testid="hero">
  <div class="mx-auto w-full max-w-5xl px-4">
    <div class="relative grid place-items-center">
      <div class="relative w-full overflow-hidden rounded-[2rem] border border-border/60 bg-black/30 shadow-[0_24px_80px_rgba(0,0,0,0.25)] aspect-[16/9] max-h-[70svh] min-h-[18rem]">
        <div class="absolute inset-0">
          <video
            class="h-full w-full object-cover motion-reduce:hidden"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            poster={posterImage}
            aria-label={videoAlt}
            data-testid="hero-video"
          >
            <source src={demoVideo} type="video/mp4" />
            <img class="h-full w-full object-cover" src={posterImage} alt={videoAlt} />
          </video>
          <img
            class="hidden h-full w-full object-cover motion-reduce:block"
            src={posterImage}
            alt={videoAlt}
          />
          <div
            class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/55"
            aria-hidden="true"
          ></div>
        </div>

        <div class="relative z-10 flex h-full items-center justify-center px-6 py-10">
    <span
      class="text-balance text-center text-[clamp(2.4rem,9vw,5.5rem)] font-semibold tracking-[0.08em] text-white drop-shadow-[0_8px_28px_rgba(0,0,0,0.45)]"
      data-testid="hero-overlay"
    >
      ub-MOJI
    </span>
        </div>
      </div>
    </div>
  </div>
</section>
