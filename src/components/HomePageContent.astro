---
import { Button } from "@/components/ui/button";
import type { Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
---

<div class="flex min-h-svh p-6">
  <div class="flex max-w-md min-w-0 flex-col gap-4 text-sm leading-loose">
    <div>
      <h1 class="font-medium">{t(locale, "heroTitle")}</h1>
      <p>{t(locale, "heroBody1")}</p>
      <p>{t(locale, "heroBody2")}</p>
      <Button client:load className="mt-2">
        {t(locale, "buttonLabel")}
      </Button>
    </div>
  </div>
</div>
