---
import type { Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";

type Props = {
  defaultArticleHref?: string | null;
  indexHref: string;
  locale: Locale;
};

const { defaultArticleHref, indexHref, locale } = Astro.props as Props;
---

<div class="rounded-[2rem] border border-border/70 bg-card/80 p-8 shadow-xs sm:p-10">
  <div class="max-w-2xl space-y-4">
    <span class="inline-flex rounded-full bg-muted px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">
      {t(locale, "newsUnavailableEyebrow")}
    </span>
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
      {t(locale, "newsUnavailableTitle")}
    </h1>
    <p class="text-base leading-7 text-muted-foreground">
      {t(locale, "newsUnavailableBody")}
    </p>
  </div>

  <div class="mt-8 flex flex-col gap-3 sm:flex-row">
    <a
      href={indexHref}
      class="inline-flex items-center justify-center rounded-full bg-primary px-5 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
    >
      {t(locale, "newsUnavailableIndexCta")}
    </a>
    {defaultArticleHref ? (
      <a
        href={defaultArticleHref}
        class="inline-flex items-center justify-center rounded-full border border-border bg-background px-5 py-3 text-sm font-medium text-foreground transition-colors hover:bg-muted/60"
      >
        {t(locale, "newsUnavailableDefaultCta")}
      </a>
    ) : null}
  </div>
</div>
