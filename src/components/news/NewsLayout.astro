---
import type { Locale } from "@/lib/i18n";

type Props = {
  eyebrow?: string;
  intro?: string;
  locale: Locale;
  title: string;
};

const { eyebrow, intro, title } = Astro.props as Props;
---

<section class="relative overflow-hidden border-b border-border/70 bg-linear-to-b from-muted/50 via-background to-background">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-border to-transparent"></div>
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-6 px-4 py-14 sm:px-6 sm:py-18">
    {eyebrow ? (
      <span class="text-xs font-semibold uppercase tracking-[0.32em] text-muted-foreground">
        {eyebrow}
      </span>
    ) : null}
    <div class="max-w-3xl space-y-4">
      <h1 class="text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">
        {title}
      </h1>
      {intro ? <p class="text-base leading-7 text-muted-foreground sm:text-lg">{intro}</p> : null}
    </div>
    <slot name="meta" />
  </div>
</section>

<div class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 sm:py-12">
  <slot />
</div>
