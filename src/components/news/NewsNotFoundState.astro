---
import type { Locale } from "@/lib/i18n";
import { t } from "@/lib/i18n";

type Props = {
  indexHref: string;
  locale: Locale;
};

const { indexHref, locale } = Astro.props as Props;
---

<div class="rounded-[2rem] border border-dashed border-border bg-muted/30 p-8 sm:p-10">
  <div class="max-w-2xl space-y-4">
    <span class="inline-flex rounded-full bg-background px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">
      404
    </span>
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{t(locale, "newsNotFoundTitle")}</h1>
    <p class="text-base leading-7 text-muted-foreground">{t(locale, "newsNotFoundBody")}</p>
  </div>

  <div class="mt-8">
    <a
      href={indexHref}
      class="inline-flex items-center justify-center rounded-full bg-primary px-5 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
    >
      {t(locale, "newsNotFoundIndexCta")}
    </a>
  </div>
</div>
