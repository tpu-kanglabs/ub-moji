---
import DatasetOverview from "@/components/dataset/DatasetOverview.astro";
import UbMojiDatasetSection from "@/components/dataset/UbMojiDatasetSection.astro";
import Hero from "@/components/hero/Hero.astro";
import Layout from "@/layouts/main.astro";
import { resolveLocale } from "@/lib/i18n";
import { getLangStaticPaths } from "@/lib/routes";

export const getStaticPaths = getLangStaticPaths;

const locale = resolveLocale(Astro.params.lang);
---

<Layout lang={locale}>
  <Hero />
  <DatasetOverview locale={locale} />
  <UbMojiDatasetSection locale={locale} />
</Layout>
