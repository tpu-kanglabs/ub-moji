---
import PageLayout from "@/components/PageLayout.astro";
import PapersSection from "@/components/papers/PapersSection.astro";
import Layout from "@/layouts/main.astro";
import { resolveLocale, t } from "@/lib/i18n";
import { getLangStaticPaths } from "@/lib/routes";
import { getCollection } from "astro:content";

export const getStaticPaths = getLangStaticPaths;

const locale = resolveLocale(Astro.params.lang);
const papers = await getCollection("papers");
---

<Layout
  lang={locale}
  title={t(locale, "papersIndexTitle")}
  description={t(locale, "papersIndexIntro")}
>
  <PageLayout
    eyebrow={t(locale, "papersIndexEyebrow")}
    title={t(locale, "papersIndexTitle")}
    intro={t(locale, "papersIndexIntro")}
  >
    <PapersSection papers={papers} locale={locale} />
  </PageLayout>
</Layout>
