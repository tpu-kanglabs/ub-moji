---
import NewsIndex from "@/components/news/NewsIndex.astro";
import PageLayout from "@/components/PageLayout.astro";
import Layout from "@/layouts/main.astro";
import { resolveLocale, t } from "@/lib/i18n";
import { getNewsIndexItems } from "@/lib/news";
import { getLangStaticPaths } from "@/lib/routes";
import { getCollection } from "astro:content";

export const getStaticPaths = getLangStaticPaths;

const locale = resolveLocale(Astro.params.lang);
const basePath = import.meta.env.BASE_URL;
const entries = getNewsIndexItems(
  await getCollection("news"),
  locale,
  basePath,
);
---

<Layout lang={locale} title={t(locale, "newsIndexTitle")} description={t(locale, "newsIndexIntro")}>
  <PageLayout
    eyebrow={t(locale, "newsIndexEyebrow")}
    title={t(locale, "newsIndexTitle")}
    intro={t(locale, "newsIndexIntro")}
  >
    <NewsIndex slot="default" entries={entries} locale={locale} />
  </PageLayout>
</Layout>
