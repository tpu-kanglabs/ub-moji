---
import Layout from "@/layouts/main.astro";
import NewsLayout from "@/components/news/NewsLayout.astro";
import PapersSection from "@/components/papers/PapersSection.astro";
import { defaultLocale, isLocale, locales, t } from "@/lib/i18n";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return locales
    .filter((lang) => lang !== defaultLocale)
    .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = isLocale(lang) ? lang : defaultLocale;
const papers = await getCollection("papers");
---

<Layout
  lang={locale}
  title={t(locale, "papersIndexTitle")}
  description={t(locale, "papersIndexIntro")}
>
  <NewsLayout
    locale={locale}
    eyebrow={t(locale, "papersIndexEyebrow")}
    title={t(locale, "papersIndexTitle")}
    intro={t(locale, "papersIndexIntro")}
  >
    <PapersSection papers={papers} locale={locale} />
  </NewsLayout>
</Layout>
