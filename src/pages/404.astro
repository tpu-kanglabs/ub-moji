---
import PageLayout from "@/components/PageLayout.astro";
import NewsNotFoundState from "@/components/news/NewsNotFoundState.astro";
import Layout from "@/layouts/main.astro";
import { getLocaleFromPath, t } from "@/lib/i18n";
import { buildSectionIndexPath } from "@/lib/routes";

const locale = getLocaleFromPath(Astro.url.pathname);
const basePath = import.meta.env.BASE_URL;
---

<Layout lang={locale} noindex={true}>
  <PageLayout
    eyebrow="404"
    title={t(locale, "newsNotFoundTitle")}
    intro={t(locale, "newsNotFoundBody")}
  >
    <NewsNotFoundState
      slot="default"
      indexHref={buildSectionIndexPath("news", locale, basePath)}
      locale={locale}
    />
  </PageLayout>
</Layout>
