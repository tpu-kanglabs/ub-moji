---
import NewsIndex from "@/components/news/NewsIndex.astro";
import NewsLayout from "@/components/news/NewsLayout.astro";
import Layout from "@/layouts/main.astro";
import { defaultLocale, t } from "@/lib/i18n";
import { getNewsIndexItems } from "@/lib/news";
import { getCollection } from "astro:content";

const locale = defaultLocale;
const basePath = import.meta.env.BASE_URL;
const entries = getNewsIndexItems(
  await getCollection("news"),
  locale,
  basePath,
);
---

<Layout lang={locale}>
  <NewsLayout
    locale={locale}
    eyebrow={t(locale, "newsIndexEyebrow")}
    title={t(locale, "newsIndexTitle")}
    intro={t(locale, "newsIndexIntro")}
  >
    <NewsIndex slot="default" entries={entries} locale={locale} />
  </NewsLayout>
</Layout>
